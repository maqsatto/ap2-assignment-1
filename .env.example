ORDER_DB_URL=postgres://postgres:postgres@order-db:5432/order_db?sslmode=disable
PAYMENT_DB_URL=postgres://postgres:postgres@payment-db:5432/payment_db?sslmode=disable
PAYMENT_GRPC_ADDR=payment-service:50051
PAYMENT_GRPC_PORT=50051
PAYMENT_HTTP_PORT=8081
ORDER_GRPC_PORT=50052
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

REDIS_ADDR=redis:6379
ORDER_CACHE_TTL=5m
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=1m

PROVIDER_MODE=SIMULATED
SIMULATED_PROVIDER_LATENCY=300ms
SIMULATED_PROVIDER_FAILURE_RATE=15
NOTIFICATION_MAX_ATTEMPTS=3
NOTIFICATION_IDEMPOTENCY_TTL=24h
